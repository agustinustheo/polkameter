{
  "version": 1,
  "testPlan": {
    "name": "Fresh Zombienet CLI smoke",
    "description": "One finalized transfer through a fresh local Zombienet relay.",
    "seed": 17,
    "limits": {
      "wholeRunTimeoutMs": 120000,
      "shutdownDrainTimeoutMs": 30000,
      "maxConcurrentSamples": 1
    }
