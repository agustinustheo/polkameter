              }
            },
            "value": "1000000000"
          },
          "completion": "finalized",
          "mortalityPeriod": 64,
          "finalityTimeoutMs": 60000,
          "assertions": []
        }
      ]
    }
  ],
  "collectors": ["jtl"]
